---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/blog/${post.id}/`} class="block p-5 rounded-xl border border-slate-200 hover:border-slate-300 hover:shadow-sm transition-all">
    <div class="flex items-center gap-2 text-xs text-slate-500 mb-2">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {tags.length > 0 && (
        <>
          <span>·</span>
          <span class="flex gap-1">
            {tags.slice(0, 2).map((tag) => (
              <span class="px-2 py-0.5 bg-slate-100 rounded-full">{tag}</span>
            ))}
          </span>
        </>
      )}
    </div>
    <h3 class="text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors mb-1.5 leading-snug tracking-tight">
      {title}
    </h3>
    <p class="text-sm text-slate-600 leading-relaxed line-clamp-2">{description}</p>
  </a>
</article>
