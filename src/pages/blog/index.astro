---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Arsovo"
  description="Every Arsovo article: reviews, comparisons, and tutorials for AI coding tools."
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-3">Blog</h1>
    <p class="text-lg text-slate-600 mb-10 leading-relaxed">
      Everything we've written, newest first.
    </p>
    {posts.length === 0 ? (
      <p class="text-slate-500">No posts yet. Check back soon.</p>
    ) : (
      <div class="grid gap-4">
        {posts.map((post) => <PostCard {post} />)}
      </div>
    )}
  </section>
</BaseLayout>
